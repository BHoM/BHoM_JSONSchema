{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/InteroperabilityTest_oM/Interoperability/Settings/InteropabilityTestSettings.json",
  "title" : "InteropabilityTestSettings",
  "type" : ["object", "null"],
  "description" : "InteropabilityTestSettings: All settings needed to run a PushPullCompare for a specific adapter.",
  "properties" : {
    "AdapterType" : {
      "type" : ["object", "null"],
      "properties" : {
        "_t" : {
          "type" : "string",
          "const" : "System.Type"
        },
        "Name" : {
          "type" : ["string", "null"]
        }
      }
    },
    "AdapterConstructorArguments" : {
      "type" : ["array", "null"],
      "description" : "The arguments required by the constructor of the adapter with the largest set of arguments.",
      "items" : { }
    },
    "TestTypes" : {
      "type" : ["array", "null"],
      "description" : "The types of objects to be tested",
      "items" : {
        "type" : ["object", "null"],
        "properties" : {
          "_t" : {
            "type" : "string",
            "const" : "System.Type"
          },
          "Name" : {
            "type" : ["string", "null"]
          }
        }
      }
    },
    "PushPullConfig" : {
      "description" : "Config to be used for the PushPullCompare method.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/InteroperabilityTest_oM/Interoperability/PushPullCompareConfig.json"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Test.Interoperability.Settings.InteropabilityTestSettings"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["AdapterType", "AdapterConstructorArguments", "TestTypes", "PushPullConfig"]
}
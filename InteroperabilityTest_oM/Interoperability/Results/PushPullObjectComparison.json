{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/InteroperabilityTest_oM/Interoperability/Results/PushPullObjectComparison.json",
  "title" : "PushPullObjectComparison",
  "type" : ["object", "null"],
  "properties" : {
    "Message" : {
      "type" : ["string", "null"],
      "description" : "Message raised during the execution."
    },
    "Status" : {
      "description" : "Severity of the message. TestStatus: Defines the status of the Test Information. Designed to be very clear, concrete statuses, with minimal ambiguity.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Test_oM/TestStatus.json"
    },
    "UTCTime" : {
      "type" : "object",
      "properties" : {
        "$date" : {
          "type" : "integer"
        }
      }
    },
    "ObjectType" : {
      "type" : ["object", "null"],
      "properties" : {
        "_t" : {
          "type" : "string",
          "const" : "System.Type"
        },
        "Name" : {
          "type" : ["string", "null"]
        }
      }
    },
    "PropertyID" : {
      "type" : ["string", "null"],
      "description" : "The name of the evaluated property. Empty if result type is Equal or Exception."
    },
    "PushedItem" : {
      "type" : ["string", "null"],
      "description" : "The value of the property on input as a string. Empty if result type is Equal or Exception."
    },
    "ReturnedItem" : {
      "type" : ["string", "null"],
      "description" : "The returned value of the property as a string. Empty if result type is Equal or Exception."
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Test.Interoperability.Results.PushPullObjectComparison"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Message", "Status", "UTCTime", "ObjectType", "PropertyID", "PushedItem", "ReturnedItem"]
}
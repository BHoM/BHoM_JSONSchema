{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Revit_oM/Elements/PipeSize.json",
  "title" : "PipeSize",
  "type" : ["object", "null"],
  "description" : "PipeSize: A wrapper BHoM type for Revit MEPSize, used to create or update Revit MEPSize (on Push) and represent them as BHoMObjects (on Pull).",
  "properties" : {
    "NominalDiameter" : {
      "type" : "number",
      "description" : "Nominal diameter of MEP Size."
    },
    "InnerDiameter" : {
      "type" : "number",
      "description" : "Inner diameter of MEP Size."
    },
    "OuterDiameter" : {
      "type" : "number",
      "description" : "Inner diameter of MEP Size."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Adapters.Revit.Elements.PipeSize"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["NominalDiameter", "InnerDiameter", "OuterDiameter"]
}
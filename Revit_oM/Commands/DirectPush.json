{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Revit_oM/Commands/DirectPush.json",
  "title" : "DirectPush",
  "type" : ["object", "null"],
  "description" : "DirectPush: Push action allows quick transfer of selected objects on current UI to External Application.",
  "properties" : {
    "ObjectsToPush" : {
      "type" : ["array", "null"],
      "description" : "Source objects to be pushed",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/BHoM/IObject.json"
      }
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Adapters.Revit.Commands.DirectPush"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["ObjectsToPush"]
}
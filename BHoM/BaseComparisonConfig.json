{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/BaseComparisonConfig.json",
  "required" : ["_t"],
  "properties" : {
    "_t" : {
      "enum" : ["BH.oM.Adapters.Revit.RevitComparisonConfig", "BH.oM.Base.ComparisonConfig"]
    }
  },
  "allOf" : [{
      "if" : {
        "properties" : {
          "_t" : {
            "type" : "string",
            "const" : "BH.oM.Adapters.Revit.RevitComparisonConfig"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Revit_oM/RevitComparisonConfig.json"
      }
    }, {
      "if" : {
        "properties" : {
          "_t" : {
            "type" : "string",
            "const" : "BH.oM.Base.ComparisonConfig"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/ComparisonConfig.json"
      }
    }]
}
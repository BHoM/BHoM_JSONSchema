            "const" : "BH.oM.Base.HashFragment"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/BHoM/HashFragment.json"
      }
    }, {
      "if" : {
        "properties" : {
          "_t" : {
            "type" : "string",
            "const" : "BH.oM.Diffing.RevisionFragment"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Diffing_oM/RevisionFragment.json"
      }
    }]
}
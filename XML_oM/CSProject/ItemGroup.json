{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/XML_oM/CSProject/ItemGroup.json",
  "title" : "ItemGroup",
  "type" : ["object", "null"],
  "properties" : {
    "References" : {
      "type" : ["array", "null"],
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/XML_oM/CSProject/Reference.json"
      }
    },
    "CompiledFiles" : {
      "type" : ["array", "null"],
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/XML_oM/CSProject/IncludedFile.json"
      }
    },
    "OtherFiles" : {
      "type" : ["array", "null"],
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/XML_oM/CSProject/IncludedFile.json"
      }
    },
    "ProjectReferences" : {
      "type" : ["array", "null"],
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/XML_oM/CSProject/ProjectReference.json"
      }
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.XML.CSProject.ItemGroup"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["References", "CompiledFiles", "OtherFiles", "ProjectReferences"]
}
    }
  },
  "required" : ["Failure", "TestCases", "Type", "ID", "Name", "FullName", "Classname", "RunState", "TestCaseCount", "Result", "Site", "StartTime", "EndTime", "Duration", "Total", "Passed", "Failed", "Warnings", "Inconclusive", "Skipped", "Asserts", "Text", "Children", "Environment", "Settings", "Properties", "Reason"]

      }
    },
    "Type" : {
      "type" : ["string", "null"]
    },
    "ID" : {
      "type" : ["string", "null"]
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "FullName" : {
      "type" : ["string", "null"]
    },
    "Classname" : {
      "type" : ["string", "null"]
    },
    "RunState" : {
      "type" : ["string", "null"]
    },
    "TestCaseCount" : {

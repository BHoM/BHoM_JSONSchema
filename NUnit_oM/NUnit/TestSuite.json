    },
    "Total" : {
      "type" : "integer"
    },
    "Passed" : {
      "type" : "integer"
    },
    "Failed" : {
      "type" : "integer"
    },
    "Warnings" : {
      "type" : "integer"
    },
    "Inconclusive" : {
      "type" : "integer"
    },
    "Skipped" : {
      "type" : "integer"
    },
    "Asserts" : {
      "type" : "integer"
    },
    "Text" : {
      "type" : ["string", "null"]
    },
    "Children" : {
      "type" : ["array", "null"],
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/NUnit_oM/NUnit/TestSuite.json"
      }

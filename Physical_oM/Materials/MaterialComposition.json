{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Physical_oM/Materials/MaterialComposition.json",
  "title" : "MaterialComposition",
  "type" : ["object", "null"],
  "description" : "MaterialComposition: Defines the make up of an object through a list of Materials as relative proportions of the total solid volume.\nThere must be the same number of items in both lists, assigning a single Ratio for each Material.",
  "properties" : {
    "Materials" : {
      "type" : ["object", "null"],
      "properties" : {
        "_v" : {
          "type" : ["array", "null"],
          "description" : "The Materials that form an object's make up, the order of which corresponds to the order of the Ratios.",
          "items" : {
            "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Physical_oM/Materials/Material.json"
          }
        }
      }
    },
    "Ratios" : {
      "type" : ["object", "null"],
      "properties" : {
        "_v" : {
          "type" : ["array", "null"],
          "description" : "The list of Material volumetric Ratios. The sum of which must equate to one. Property has a quantity of type Ratio measured in [-].",
          "items" : {
            "type" : "number"
          }
        }
      }
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Physical.Materials.MaterialComposition"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Materials", "Ratios"]
}
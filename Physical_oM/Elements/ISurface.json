            "const" : "BH.oM.Physical.Elements.Wall"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Physical_oM/Elements/Wall.json"
      }
    }]

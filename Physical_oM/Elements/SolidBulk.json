{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Physical_oM/Elements/SolidBulk.json",
  "title" : "SolidBulk",
  "type" : ["object", "null"],
  "properties" : {
    "Geometry" : {
      "type" : ["array", "null"],
      "description" : "A list of geometric solids defining the bulk geometry.",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Geometry_oM/ISolid.json"
      }
    },
    "MaterialComposition" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Physical_oM/Materials/MaterialComposition.json"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Physical.Elements.SolidBulk"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Geometry", "MaterialComposition"]
}
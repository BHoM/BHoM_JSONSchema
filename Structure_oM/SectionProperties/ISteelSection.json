{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Structure_oM/SectionProperties/ISteelSection.json",
  "required" : ["_t"],
  "properties" : {
    "_t" : {
      "enum" : ["BH.oM.Structure.SectionProperties.CellularSection", "BH.oM.Structure.SectionProperties.SteelSection"]
    }
  },
  "allOf" : [{
      "if" : {
        "properties" : {
          "_t" : {
            "type" : "string",
            "const" : "BH.oM.Structure.SectionProperties.CellularSection"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Structure_oM/SectionProperties/CellularSection.json"
      }
    }, {
      "if" : {
        "properties" : {
          "_t" : {
            "type" : "string",
            "const" : "BH.oM.Structure.SectionProperties.SteelSection"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Structure_oM/SectionProperties/SteelSection.json"
      }
    }]
}
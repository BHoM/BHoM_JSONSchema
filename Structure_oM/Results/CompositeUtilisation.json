{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Structure_oM/Results/CompositeUtilisation.json",
  "title" : "CompositeUtilisation",
  "type" : ["object", "null"],
  "description" : "CompositeUtilisation: Base class for all bar result classes. Stores all identifier information and how to sort the results in a collection.",
  "properties" : {
    "MinorEffectiveLength" : {
      "type" : ["string", "null"]
    },
    "MajorEffectiveLength" : {
      "type" : ["string", "null"]
    },
    "SteelClass" : {
      "type" : "integer"
    },
    "TensionCompressionRatio" : {
      "type" : "number"
    },
    "MinorBendingRatio" : {
      "type" : "number"
    },
    "MajorBendingRatio" : {
      "type" : "number"
    },
    "MinorBendingAxialRatio" : {
      "type" : "number"
    },
    "MajorBendingAxialRatio" : {
      "type" : "number"
    },
    "BiaxialBendingAxialRatio" : {
      "type" : "number"
    },
    "MinorShearRatio" : {
      "type" : "number"
    },
    "MajorShearRatio" : {
      "type" : "number"
    },
    "MinorBendingShearRatio" : {
      "type" : "number"
    },
    "MajorBendingShearRatio" : {
      "type" : "number"
    },
    "CompressionBucklingRatio" : {
      "type" : "number"
    },
    "BendingBucklingRatio" : {
      "type" : "number"
    },
    "BendingCompressionBucklingRatio" : {
      "type" : "number"
    },
    "ObjectId" : {
      "type" : ["object", "integer", "string", "number", "null"]
    },
    "ResultCase" : {
      "type" : ["object", "integer", "string", "number", "null"]
    },
    "ModeNumber" : {
      "type" : "integer",
      "description" : "Positive index, starting at one. Only set for cases with modal outputs such as dynamic cases."
    },
    "TimeStep" : {
      "type" : "number",
      "description" : "Time step for time history results."
    },
    "Position" : {
      "type" : "number",
      "description" : "Position on the bar as normalised length, i.e. 0 for start, 1 for end and 0.5 for middle."
    },
    "Divisions" : {
      "type" : "integer",
      "description" : "How many division points along the bar was used when extracting this result. This generally means that this many results with the same ObjectId, ResultCase and TimeStep was extracted."
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Structure.Results.CompositeUtilisation"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["MinorEffectiveLength", "MajorEffectiveLength", "SteelClass", "TensionCompressionRatio", "MinorBendingRatio", "MajorBendingRatio", "MinorBendingAxialRatio", "MajorBendingAxialRatio", "BiaxialBendingAxialRatio", "MinorShearRatio", "MajorShearRatio", "MinorBendingShearRatio", "MajorBendingShearRatio", "CompressionBucklingRatio", "BendingBucklingRatio", "BendingCompressionBucklingRatio", "ObjectId", "ResultCase", "ModeNumber", "TimeStep", "Position", "Divisions"]
}
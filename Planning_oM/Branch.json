{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Planning_oM/Branch.json",
  "title" : "Branch",
  "type" : ["object", "null"],
  "properties" : {
    "LastPusher" : {
      "type" : ["string", "null"]
    },
    "Title" : {
      "type" : ["string", "null"]
    },
    "RepoName" : {
      "type" : ["string", "null"]
    },
    "Protected" : {
      "type" : "boolean"
    },
    "LastCommitDate" : {
      "type" : "array",
      "prefixItems" : [{
          "type" : "integer"
        }, {
          "type" : "integer"
        }],
      "items" : false
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Planning.Branch"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["LastPusher", "Title", "RepoName", "Protected", "LastCommitDate"]
}
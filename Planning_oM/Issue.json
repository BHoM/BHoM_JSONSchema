{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Planning_oM/Issue.json",
  "title" : "Issue",
  "type" : ["object", "null"],
  "properties" : {
    "Creator" : {
      "type" : ["string", "null"]
    },
    "Assignees" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      }
    },
    "Title" : {
      "type" : ["string", "null"]
    },
    "RepoName" : {
      "type" : ["string", "null"]
    },
    "Number" : {
      "type" : "integer"
    },
    "CreationDate" : {
      "type" : "array",
      "prefixItems" : [{
          "type" : "integer"
        }, {
          "type" : "integer"
        }],
      "items" : false
    },
    "MilestoneName" : {
      "type" : ["string", "null"]
    },
    "PullRequested" : {
      "type" : "boolean"
    },
    "Labels" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      }
    },
    "Url" : {
      "type" : ["string", "null"]
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Planning.Issue"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Creator", "Assignees", "Title", "RepoName", "Number", "CreationDate", "MilestoneName", "PullRequested", "Labels", "Url"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Planning_oM/Commit.json",
  "title" : "Commit",
  "type" : ["object", "null"],
  "properties" : {
    "RepoName" : {
      "type" : ["string", "null"]
    },
    "Date" : {
      "type" : "array",
      "prefixItems" : [{
          "type" : "integer"
        }, {
          "type" : "integer"
        }],
      "items" : false
    },
    "Author" : {
      "type" : ["string", "null"]
    },
    "Committer" : {
      "type" : ["string", "null"]
    },
    "Additions" : {
      "type" : "integer"
    },
    "Deletions" : {
      "type" : "integer"
    },
    "TotalChanges" : {
      "type" : "integer"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Planning.Commit"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["RepoName", "Date", "Author", "Committer", "Additions", "Deletions", "TotalChanges"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Architecture_oM/Theatron/TheatronFullProfile.json",
  "title" : "TheatronFullProfile",
  "type" : ["object", "null"],
  "properties" : {
    "BaseTierProfiles" : {
      "type" : ["array", "null"],
      "description" : "The set of tier profiles orientated in the world xz plane, the origin is the focal point for Cvalue calculations",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Architecture_oM/Theatron/TierProfile.json"
      }
    },
    "MappedProfiles" : {
      "type" : ["array", "null"],
      "description" : "The set of tier profiles orientated to the plane closest to the focal curve",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Architecture_oM/Theatron/TierProfile.json"
      }
    },
    "Rounding" : {
      "type" : "number"
    },
    "FullProfileOrigin" : {
      "description" : "The plane at the first surface point, x axis is horizontal and points away from the playing area, y axis points up ProfileOrigin: Used for orientation and setting out of tier profiles",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Architecture_oM/Theatron/ProfileOrigin.json"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Architecture.Theatron.TheatronFullProfile"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["BaseTierProfiles", "MappedProfiles", "Rounding", "FullProfileOrigin"]
}
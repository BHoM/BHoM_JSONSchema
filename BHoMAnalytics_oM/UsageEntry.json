    },
    "SelectedItem" : { },
    "Computer" : {
      "type" : ["string", "null"]
    },
    "Username" : {
      "type" : ["string", "null"]
    },
    "BHoMVersion" : {
      "type" : ["string", "null"]
    },
    "FileId" : {
      "type" : ["string", "null"]
    },
    "FileName" : {
      "type" : ["string", "null"]

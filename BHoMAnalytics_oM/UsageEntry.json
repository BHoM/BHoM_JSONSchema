  "required" : ["StartTime", "EndTime", "UI", "UiVersion", "CallerName", "SelectedItem", "Computer", "Username", "BHoMVersion", "FileId", "FileName", "ProjectID", "NbCallingComponents", "TotalNbCalls", "Errors"]

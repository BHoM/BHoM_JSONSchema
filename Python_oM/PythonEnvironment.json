{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Python_oM/PythonEnvironment.json",
  "title" : "PythonEnvironment",
  "type" : ["object", "null"],
  "properties" : {
    "Name" : {
      "type" : ["string", "null"],
      "description" : "The name of this BHoM Python Environment."
    },
    "Executable" : {
      "type" : ["string", "null"],
      "description" : "The path to this Python Environments executable."
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Python.PythonEnvironment"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Name", "Executable"]
}
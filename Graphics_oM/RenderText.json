{
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.2/Graphics_oM/RenderText.json",
  "title" : "RenderText",
  "type" : ["object", "null"],
  "description" : "RenderText: Render text at a location and orientation in space with specified height, font and colour.",
  "properties" : {
    "Text" : {
      "type" : ["string", "null"],
      "description" : "The text to render."
    },

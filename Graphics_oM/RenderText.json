    "FontName" : {
      "type" : ["string", "null"],
      "description" : "Font used to render the text. Default is Arial."
    },
    "Colour" : {
      "type" : ["object", "null"],
      "properties" : {
        "_t" : {
          "type" : ["string", "null"],
          "const" : "System.Drawing.Color"
        },
        "A" : {
          "type" : "integer"
        },
        "R" : {
          "type" : "integer"
        },
        "G" : {
          "type" : "integer"
        },
        "B" : {
          "type" : "integer"
        }
      },
      "required" : ["A", "R", "G", "B"]
    },
    "_t" : {
      "type" : ["string", "null"],
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Graphics.RenderText"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Text", "Cartesian", "Height", "FontName", "Colour"]
}
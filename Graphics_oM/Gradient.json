{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Graphics_oM/Gradient.json",
  "title" : "Gradient",
  "type" : ["object", "null"],
  "properties" : {
    "Markers" : {
      "type" : ["array", "null"],
      "description" : "A SortedDictionary of 'Color's using a 'decimal' between 0 and 1 as Key. Is used to get a interpolated 'Color' from a value between 0 and 1",
      "items" : {
        "type" : "object",
        "properties" : {
          "k" : {
            "type" : "object",
            "properties" : {
              "$numberDecimal" : {
                "type" : ["string", "null"]
              }
            }
          },
          "v" : {
            "type" : "object",
            "properties" : {
              "_t" : {
                "type" : "string",
                "const" : "System.Drawing.Color"
              },
              "A" : {
                "type" : "integer"
              },
              "R" : {
                "type" : "integer"
              },
              "G" : {
                "type" : "integer"
              },
              "B" : {
                "type" : "integer"
              }
            },
            "required" : ["A", "R", "G", "B"]
          }
        }
      }
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Graphics.Gradient"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Markers"]
}
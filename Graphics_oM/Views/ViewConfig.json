{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Graphics_oM/Views/ViewConfig.json",
  "title" : "ViewConfig",
  "type" : ["object", "null"],
  "description" : "ViewConfig: Configuration properties for view objects.",
  "properties" : {
    "Width" : {
      "type" : "number"
    },
    "Height" : {
      "type" : "number"
    },
    "Padding" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Graphics_oM/Misc/Padding.json"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Graphics.Views.ViewConfig"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Width", "Height", "Padding"]
}
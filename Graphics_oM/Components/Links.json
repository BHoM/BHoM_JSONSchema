{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Graphics_oM/Components/Links.json",
  "title" : "Links",
  "type" : ["object", "null"],
  "description" : "Links: Basic link representation for relationships between entities.",
  "properties" : {
    "Text" : {
      "type" : ["string", "null"]
    },
    "Start" : {
      "type" : ["string", "null"]
    },
    "End" : {
      "type" : ["string", "null"]
    },
    "Colour" : {
      "type" : ["string", "null"]
    },
    "Marker" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Graphics_oM/Components/IMarker.json"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },

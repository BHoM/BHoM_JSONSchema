{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Graphics_oM/Components/Boxes.json",
  "title" : "Boxes",
  "type" : ["object", "null"],
  "description" : "Boxes: Rectangular box configuration for representation of entity boundaries.",
  "properties" : {

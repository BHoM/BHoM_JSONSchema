{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Graphics_oM/RenderCurve.json",
  "title" : "RenderCurve",
  "type" : ["object", "null"],
  "description" : "RenderCurve: Render a curve with specified colour and thickness.",
  "properties" : {
    "Curve" : {
      "description" : "The curve to render. ICurve: The interface for all one-dimensional geometrical objects.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Geometry_oM/ICurve.json"
    },
    "Thickness" : {
      "type" : "integer",
      "description" : "The thickness of the curve. Should be a value greater or equal to 1."
    },
    "Colour" : {
      "type" : "object",
      "properties" : {
        "_t" : {
          "type" : "string",
          "const" : "System.Drawing.Color"
        },
        "A" : {
          "type" : "integer"
        },
        "R" : {
          "type" : "integer"
        },
        "G" : {
          "type" : "integer"
        },
        "B" : {
          "type" : "integer"
        }
      },
      "required" : ["A", "R", "G", "B"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Graphics.RenderCurve"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Curve", "Thickness", "Colour"]
}
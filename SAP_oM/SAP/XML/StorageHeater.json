{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/SAP_oM/SAP/XML/StorageHeater.json",
  "title" : "StorageHeater",
  "type" : ["object", "null"],
  "properties" : {
    "NumberOfHeaters" : {
      "type" : "integer",
      "description" : "The number of storage heaters with this index number."
    },
    "IndexNumber" : {
      "type" : ["string", "null"],
      "description" : "The index number of the heater from the product database."
    },
    "HighHeatRetention" : {
      "type" : ["boolean", "null"],
      "description" : "Whether heater is high heat retention type."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Environment.SAP.XML.StorageHeater"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["NumberOfHeaters", "IndexNumber", "HighHeatRetention"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/SAP_oM/SAP/Excel/FloorSchedule.json",
  "title" : "FloorSchedule",
  "type" : ["object", "null"],
  "description" : "FloorSchedule: The details of floors from the users excel input.",
  "properties" : {
    "Dwelling" : {
      "type" : ["string", "null"],
      "description" : "The name of the dwelling the floor is located in."
    },
    "Type" : {
      "description" : "The type of floor TypeOfFloor: Code which indicates the type of floor (exposure).",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/SAP_oM/SAP/TypeOfFloor.json"
    },
    "Storey" : {
      "type" : ["string", "null"],
      "description" : "The storey the floor is located on."
    },
    "UValue" : {
      "type" : "number",
      "description" : "The uvalue of the floor"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Environment.SAP.Excel.FloorSchedule"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Dwelling", "Type", "Storey", "UValue"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/SAP_oM/SAP/Excel/PsiValueSchedule.json",
  "title" : "PsiValueSchedule",
  "type" : ["object", "null"],
  "description" : "PsiValueSchedule: A thermal bridge between two thermal elements of the dwelling.",
  "properties" : {
    "Type" : {
      "type" : ["string", "null"],
      "description" : "The thermal bridge type reference according to Table K1 in SAP 2012."
    },
    "ThermalBridgeName" : {
      "type" : ["string", "null"],
      "description" : "The length of the thermal bridge."
    },
    "PsiValue" : {
      "type" : "number",
      "description" : "The psi-value (heat loss per linear metre) to be applied to the thermal bridge."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Environment.SAP.Excel.PsiValueSchedule"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Type", "ThermalBridgeName", "PsiValue"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/SAP_oM/SAP/Excel/WallSchedule.json",
  "title" : "WallSchedule",
  "type" : ["object", "null"],
  "description" : "WallSchedule: The details of walls from the users excel input.",
  "properties" : {
    "Dwelling" : {
      "type" : ["string", "null"],
      "description" : "The name of the dwelling the wall is located in."
    },
    "Type" : {
      "description" : "The type of wall TypeOfWall: Code which indicates the type of wall (exposure).",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/SAP_oM/SAP/TypeOfWall.json"
    },
    "Storey" : {
      "type" : ["string", "null"],
      "description" : "The name of the wall."
    },
    "CurtainWall" : {
      "type" : "boolean",
      "description" : "If the wall is a curtain wall."
    },
    "UValue" : {
      "type" : "number",
      "description" : "The uvalue of the wall"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Environment.SAP.Excel.WallSchedule"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Dwelling", "Type", "Storey", "CurtainWall", "UValue"]
}
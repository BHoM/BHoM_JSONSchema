{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/UI_oM/CodeElementRecord.json",
  "title" : "CodeElementRecord",
  "type" : ["object", "null"],
  "properties" : {
    "AssemblyName" : {
      "type" : ["string", "null"]
    },
    "AssemblyModifiedTime" : {
      "type" : "object",
      "properties" : {
        "$date" : {
          "type" : "integer"
        }
      }
    },
    "Type" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/UI_oM/CodeElementType.json"
    },
    "DisplayText" : {
      "type" : ["string", "null"]
    },
    "Json" : {
      "type" : ["string", "null"]
    },
    "InputKeys" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      }
    },
    "OutputKeys" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      }
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.UI.CodeElementRecord"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["AssemblyName", "AssemblyModifiedTime", "Type", "DisplayText", "Json", "InputKeys", "OutputKeys"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/MEP_oM/System/SectionProperties/SectionProfile.json",
  "title" : "SectionProfile",
  "type" : ["object", "null"],
  "properties" : {
    "ElementProfile" : {
      "description" : "ShapeProfile of the element itself. This is the base ShapeProfile that determines the overall shape of the IFlow object. IProfile: Base interface for all shape profiles.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Spatial_oM/ShapeProfiles/IProfile.json"
    },
    "LiningProfile" : {
      "description" : "ShapeProfile of the element's interior lining. IProfile: Base interface for all shape profiles.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Spatial_oM/ShapeProfiles/IProfile.json"
    },
    "InsulationProfile" : {
      "description" : "ShapeProfile of the element's exterior insulation. IProfile: Base interface for all shape profiles.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Spatial_oM/ShapeProfiles/IProfile.json"
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.MEP.System.SectionProperties.SectionProfile"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["ElementProfile", "LiningProfile", "InsulationProfile"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Environment_oM/Results/ProfileResult.json",
  "title" : "ProfileResult",
  "type" : ["object", "null"],
  "description" : "ProfileResult: A Environment Profile Result object that can be added to a Simulation Result",
  "properties" : {
    "Unit" : {
      "description" : "The unit measurement of the profile result from the Profile Result enum",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Environment_oM/Results/ProfileResultUnit.json"
    },
    "Type" : {
      "description" : "The type of the profile result from the Profile Result enum",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Environment_oM/Results/ProfileResultType.json"
    },
    "Results" : {
      "type" : ["array", "null"],
      "description" : "A collection of the results of this profile",
      "items" : {
        "type" : "number"
      }
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Environment.Results.ProfileResult"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Unit", "Type", "Results"]
}
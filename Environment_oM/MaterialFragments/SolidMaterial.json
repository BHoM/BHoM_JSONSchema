    },
    "SolarTransmittance" : {
      "type" : "number"
    },
    "LightReflectanceExternal" : {
      "type" : "number"
    },
    "LightReflectanceInternal" : {
      "type" : "number"
    },
    "LightTransmittance" : {
      "type" : "number"
    },
    "EmissivityExternal" : {
      "type" : "number"
    },
    "EmissivityInternal" : {
      "type" : "number"
    },
    "Specularity" : {
      "type" : "number"
    },
    "TransmittedDiffusivity" : {
      "type" : "number"
    },
    "TransmittedSpecularity" : {
      "type" : "number"
    },

    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Environment.MaterialFragments.SolidMaterial"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Density", "Conductivity", "SpecificHeat", "VapourResistivity", "Description", "Roughness", "Refraction", "SolarReflectanceExternal", "SolarReflectanceInternal", "SolarTransmittance", "LightReflectanceExternal", "LightReflectanceInternal", "LightTransmittance", "EmissivityExternal", "EmissivityInternal", "Specularity", "TransmittedDiffusivity", "TransmittedSpecularity", "IgnoreInUValueCalculation"]

{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Environment_oM/Elements/Mesh.json",
  "title" : "Mesh",
  "type" : ["object", "null"],
  "description" : "Mesh: An environment object used to define a volumetric mesh.",
  "properties" : {
    "Mesh3D" : {
      "description" : "Defines the three-dimensional Mesh geometry. Mesh3D: A polygon mesh, defined by a list of triangular or quadrilateral Faces, Cells and their Vertices.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Geometry_oM/Mesh3D.json"
    },
    "BoundaryZones" : {
      "type" : ["array", "null"],
      "description" : "Defines the partition of the meshes external faces.",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Environment_oM/Elements/BoundaryZone.json"
      }
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Environment.Elements.Mesh"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Mesh3D", "BoundaryZones"]
}
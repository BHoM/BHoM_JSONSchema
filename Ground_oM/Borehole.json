    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      }
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : ["string", "null"],
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Ground.Borehole"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Id", "Top", "Bottom", "CoordinateSystem", "Strata", "ContaminantSamples", "GeotechnicalTestResults", "BoreholeProperties"]
}
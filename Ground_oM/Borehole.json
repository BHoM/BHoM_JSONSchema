{
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Ground_oM/Borehole.json",
  "title" : "Borehole",
  "type" : ["object", "null"],
  "description" : "Borehole: A representation of a borehole defined by a coordinate system, start point and end point based on the AGS schema.",
  "properties" : {
    "Id" : {
      "type" : ["string", "null"],
      "description" : "Location identifier for the borehole unique to the project (LOCA_ID)."
    },
    "Top" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Geometry_oM/Point.json"
    },
    "Bottom" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Geometry_oM/Point.json"
    },
    "CoordinateSystem" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Geometry_oM/CoordinateSystem/Cartesian.json"
    },
    "Strata" : {
      "type" : ["array", "null"],
      "description" : "A list of objects containing the strata found within the borehole, based on the GEOL table.",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Ground_oM/Stratum.json"
      }
    },
    "ContaminantSamples" : {
      "type" : ["array", "null"],
      "description" : "A list of objects containing the contaminant samples found within the borehole, based on the ERES table.",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Ground_oM/ContaminantSample.json"
      }
    },
    "GeotechnicalTestResults" : {
      "type" : ["array", "null"],
      "description" : "A list of objects containing the geotechnical results found within the borehole.",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Ground_oM/ITest.json"
      }
    },
    "BoreholeProperties" : {
      "type" : ["array", "null"],
      "description" : "A list of properties related to the borehole.",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Ground_oM/IBoreholeProperty.json"
      }
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {

{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Ground_oM/DetectionProperties.json",
  "title" : "DetectionProperties",
  "type" : ["object", "null"],
  "description" : "DetectionProperties: Properties related to the results based on the tests of the contaminant.",
  "properties" : {
    "DetectionLimit" : {
      "type" : "number",
      "description" : "Reporting detection limit (ERES_RDLM)."
    },
    "MethodDetectionLimit" : {
      "type" : "number",
      "description" : "Method detection limit (ERES_MDLM)."
    },
    "QuantificationLimit" : {
      "type" : "number",
      "description" : "Quanification limit (ERES_QLM)."
    },
    "TICProbability" : {
      "type" : "number",
      "description" : "Tentatively Identified Compound (TIC) probability (ERES_TICP)."
    },
    "TICRetention" : {
      "type" : "number",
      "description" : "Tentatively Identified Compound (ERES_TICT) retention time."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Ground.DetectionProperties"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["DetectionLimit", "MethodDetectionLimit", "QuantificationLimit", "TICProbability", "TICRetention"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Ground_oM/TriaxialTestProperties.json",
  "title" : "TriaxialTestProperties",
  "type" : ["object", "null"],
  "description" : "TriaxialTestProperties: Properties of the triaxial tests.",
  "properties" : {
    "SampleDiameter" : {
      "type" : "number",
      "description" : "Specimen diameter (TRIT_SDIA). Property has a quantity of type Length measured in [m]."
    },
    "SampleLength" : {
      "type" : "number",
      "description" : "Specimen length (TRIT_SLEN). Property has a quantity of type Length measured in [m]."
    },
    "TriaxialReference" : {
      "type" : ["string", "null"],
      "description" : "Triaxial test and/or stage reference (TRIT_TESN)."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Ground.TriaxialTestProperties"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["SampleDiameter", "SampleLength", "TriaxialReference"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Ground_oM/TestProperties.json",
  "title" : "TestProperties",
  "type" : ["object", "null"],
  "description" : "TestProperties: Properties related to the tests undertaken on the contaminant.",
  "properties" : {
    "LabTestName" : {
      "type" : ["string", "null"],
      "description" : "Labratory test name for the contaminant sample (ERES_TNAM)."
    },
    "Reference" : {
      "type" : ["string", "null"],
      "description" : "Test reference (TEST_TESN)."
    },
    "RunType" : {
      "type" : ["string", "null"],
      "description" : "Run type description, i.e. initial or reanalysis (ERES_RTYP)."
    },
    "TestMatrix" : {
      "type" : ["string", "null"],
      "description" : "Labratory test matrix (ERES_MATX)."
    },
    "Method" : {
      "type" : ["string", "null"],
      "description" : "Test method (ERES_METH)."
    },
    "AnalysisDate" : {
      "type" : "object",
      "properties" : {
        "$date" : {
          "type" : "integer"
        }
      }
    },
    "Description" : {
      "type" : ["string", "null"],
      "description" : "Description of the specimen from the contaminant sample (SPEC_DESC)."
    },
    "Remarks" : {
      "type" : ["string", "null"],
      "description" : "Remarks about the test or specimen from the contaminant sample (ERES_REM)."
    },
    "TestStatus" : {
      "type" : ["string", "null"],
      "description" : "The status of the test (TEST_STAT)."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Ground.TestProperties"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["LabTestName", "Reference", "RunType", "TestMatrix", "Method", "AnalysisDate", "Description", "Remarks", "TestStatus"]
}
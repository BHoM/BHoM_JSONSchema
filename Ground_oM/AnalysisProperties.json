{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Ground_oM/AnalysisProperties.json",
  "title" : "AnalysisProperties",
  "type" : ["object", "null"],
  "description" : "AnalysisProperties: Properties related to the analysis undertaken on the contaminant.",
  "properties" : {
    "TotalOrDissolved" : {
      "type" : ["string", "null"],
      "description" : "Whether the specimen is total or dissolved (ERES_TORD)."
    },
    "AccreditingBody" : {
      "type" : ["string", "null"],
      "description" : "Accrediting body and reference number (when appropriate) (ERES_CRED)."
    },
    "LabName" : {
      "type" : ["string", "null"],
      "description" : "Name of testing labratory or organisation (ERES_LAB)."
    },
    "PercentageRemoved" : {
      "type" : "number",
      "description" : "Percentage of material removed (ERES_PERP)."
    },
    "SizeRemoved" : {
      "type" : "number",
      "description" : "Size of material removed prior to test. Value represents lowest sized material removed (ERES_SIZE). Property has a quantity of type Length measured in [m]."
    },
    "InstrumentReference" : {
      "type" : ["string", "null"],
      "description" : "Instrument reference number or identifier (ERES_IREF)."
    },
    "LeachateDate" : {
      "type" : "object",
      "properties" : {
        "$date" : {
          "type" : "integer"
        }
      }
    },
    "LeachateMethod" : {
      "type" : ["string", "null"],
      "description" : "Leachate preperation method (ERES_LMTH)."
    },
    "DilutionFactor" : {
      "type" : "integer",
      "description" : "Dilution factor (ERES_DIL)."
    },
    "Basis" : {
      "type" : ["string", "null"],
      "description" : "Basis (ERES_BAS)."
    },
    "Location" : {
      "type" : ["string", "null"],
      "description" : "Analysis location (ERES_LOCN)."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Ground.AnalysisProperties"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["TotalOrDissolved", "AccreditingBody", "LabName", "PercentageRemoved", "SizeRemoved", "InstrumentReference", "LeachateDate", "LeachateMethod", "DilutionFactor", "Basis", "Location"]
}
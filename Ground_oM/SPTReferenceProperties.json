{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Ground_oM/SPTReferenceProperties.json",
  "title" : "SPTReferenceProperties",
  "type" : ["object", "null"],
  "description" : "SPTReferenceProperties: Properties related references and location of the standard penetration test.",
  "properties" : {
    "FileReference" : {
      "type" : ["string", "null"],
      "description" : "Associated file reference (FILE_FSET)."
    },
    "Remarks" : {
      "type" : ["string", "null"],
      "description" : "Remarks or Comments (ISPT_REM)."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Ground.SPTReferenceProperties"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["FileReference", "Remarks"]
}
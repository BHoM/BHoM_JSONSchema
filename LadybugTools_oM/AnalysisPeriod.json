{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/LadybugTools_oM/AnalysisPeriod.json",
  "title" : "AnalysisPeriod",
  "type" : ["object", "null"],
  "properties" : {
    "StartMonth" : {
      "type" : "integer",
      "description" : "The start month."
    },
    "StartDay" : {
      "type" : "integer",
      "description" : "The start day."
    },
    "StartHour" : {
      "type" : "integer",
      "description" : "The start hour."
    },
    "EndMonth" : {
      "type" : "integer",
      "description" : "The end month."
    },
    "EndDay" : {
      "type" : "integer",
      "description" : "The end day."
    },
    "EndHour" : {
      "type" : "integer",
      "description" : "The end hour."
    },
    "IsLeapYear" : {
      "type" : "boolean",
      "description" : "Boolean flag for whether this represents a leap year."
    },
    "TimeStep" : {
      "type" : "integer",
      "description" : "The number of timesteps per hour."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.LadybugTools.AnalysisPeriod"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["StartMonth", "StartDay", "StartHour", "EndMonth", "EndDay", "EndHour", "IsLeapYear", "TimeStep"]
}
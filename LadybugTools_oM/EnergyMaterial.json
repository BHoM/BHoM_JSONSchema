{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/LadybugTools_oM/EnergyMaterial.json",
  "title" : "EnergyMaterial",
  "type" : ["object", "null"],
  "properties" : {
    "Name" : {
      "type" : ["string", "null"],
      "description" : "The name of this EnergyMaterial."
    },
    "Thickness" : {
      "type" : "number",
      "description" : "Thickness of material (m). Property has a quantity of type Length measured in [m]."
    },
    "Conductivity" : {
      "type" : "number",
      "description" : "Conductivity of material (W/mK)."
    },
    "Density" : {
      "type" : "number",
      "description" : "Density of material (kg/m3). Property has a quantity of type Density measured in [kg/m³]."
    },
    "SpecificHeat" : {
      "type" : "number",
      "description" : "Specific heat capacity of material (J/kgK)."
    },
    "Roughness" : {
      "description" : "The roughness of the material. Roughness: An enum for the roughness of an EnergyMaterial.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/LadybugTools_oM/Roughness.json"
    },
    "ThermalAbsorptance" : {
      "type" : "number",
      "description" : "Thermal absorptivity (emissivity) of material (0-1)."
    },
    "SolarAbsorptance" : {
      "type" : "number",
      "description" : "Solar absorptivity of material (0-1)."
    },
    "VisibleAbsorptance" : {
      "type" : "number",
      "description" : "Light absorptivity (1 - albedo) of material (0-1)."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.LadybugTools.EnergyMaterial"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Name", "Thickness", "Conductivity", "Density", "SpecificHeat", "Roughness", "ThermalAbsorptance", "SolarAbsorptance", "VisibleAbsorptance"]
}
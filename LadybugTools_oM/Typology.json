{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/LadybugTools_oM/Typology.json",
  "title" : "Typology",
  "type" : ["object", "null"],
  "properties" : {
    "Name" : {
      "type" : ["string", "null"],
      "description" : "The name of this Typology."
    },
    "Shelters" : {
      "type" : ["array", "null"],
      "description" : "The shelters for this Typology.",
      "items" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/LadybugTools_oM/Shelter.json"
      }
    },
    "EvaporativeCoolingEffect" : {
      "type" : ["array", "null"],
      "description" : "The proportion of evaporative cooling to add to this Typology.",
      "items" : {
        "type" : "number"
      }
    },
    "TargetWindSpeed" : {
      "type" : ["array", "null"],
      "description" : "Override for the wind speed that will ignore any shelter effects for each time step. Leave timesteps null to use the shelter affected wind speeds (default null).",
      "items" : {
        "type" : ["number", "null"]
      }
    },
    "WindSpeedMultiplier" : {
      "type" : "number",
      "description" : "A multiplier to apply to the wind speed retrieved from the EPW file."
    },
    "RadiantTemperatureAdjustment" : {
      "type" : ["array", "null"],
      "description" : "A reduction or increase in MRT to be applied to results generated using this Typology.",
      "items" : {
        "type" : "number"
      }
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.LadybugTools.Typology"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Name", "Shelters", "EvaporativeCoolingEffect", "TargetWindSpeed", "WindSpeedMultiplier", "RadiantTemperatureAdjustment"]
}
            "const" : "BH.oM.Test.Results.EventMessage"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Test_oM/Results/EventMessage.json"
      }
    }, {
      "if" : {
        "properties" : {
          "_t" : {
            "type" : "string",
            "const" : "BH.oM.Test.Results.TestResult"
          }
        },
        "required" : ["_t"]
      },
      "then" : {
        "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/Test_oM/Results/TestResult.json"
      }
    }]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Humans_oM/Employee.json",
  "title" : "Employee",
  "type" : ["object", "null"],
  "properties" : {
    "Company" : {
      "type" : ["string", "null"],
      "description" : "Company the Employee works for."
    },
    "Office" : {
      "type" : ["string", "null"],
      "description" : "Office assigned to the Employee."
    },
    "Discipline" : {
      "type" : ["string", "null"],
      "description" : "Discipline the Employee works in."
    },
    "Team" : {
      "type" : ["string", "null"],
      "description" : "Team the Employee belongs to."
    },
    "Manager" : {
      "description" : "Manager of the Employee.",
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Humans_oM/Employee.json"
    },
    "Grade" : {
      "type" : ["string", "null"],
      "description" : "Seniority of the Employee."
    },
    "Email" : {
      "type" : ["string", "null"],
      "description" : "Company email of the Employee."
    },
    "Phone" : {
      "type" : ["string", "null"],
      "description" : "Company phone number of the Employee."
    },
    "CodeDevelopmentRole" : {
      "type" : ["string", "null"]
    },
    "BusinessUnit" : {
      "type" : ["string", "null"],
      "description" : "Business Unit the Employee is assigned to."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Humans.Employee"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Company", "Office", "Discipline", "Team", "Manager", "Grade", "Email", "Phone", "CodeDevelopmentRole", "BusinessUnit"]
}
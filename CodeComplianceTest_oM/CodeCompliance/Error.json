{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/CodeComplianceTest_oM/CodeCompliance/Error.json",
  "title" : "Error",
  "type" : ["object", "null"],
  "properties" : {
    "Message" : {
      "type" : ["string", "null"]
    },
    "Location" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/CodeComplianceTest_oM/CodeCompliance/Location.json"
    },
    "DocumentationLink" : {
      "type" : ["string", "null"]
    },
    "Status" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Test_oM/TestStatus.json"
    },
    "UTCTime" : {
      "type" : "object",
      "properties" : {
        "$date" : {
          "type" : "integer"
        }
      }
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Test.CodeCompliance.Error"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Message", "Location", "DocumentationLink", "Status", "UTCTime"]
}
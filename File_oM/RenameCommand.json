{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/File_oM/RenameCommand.json",
  "title" : "RenameCommand",
  "type" : ["object", "null"],
  "properties" : {
    "FullPath" : {
      "type" : ["string", "null"],
      "description" : "Full paths of the items to be Renamed."
    },
    "TargetFullPath" : {
      "type" : ["string", "null"],
      "description" : "The new Full paths of the Files. Files will be Renamed."
    },
    "OverwriteTarget" : {
      "type" : "boolean",
      "description" : "Whether to override the target."
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Adapters.File.RenameCommand"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["FullPath", "TargetFullPath", "OverwriteTarget"]
}
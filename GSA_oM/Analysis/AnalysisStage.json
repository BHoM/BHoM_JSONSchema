{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/GSA_oM/Analysis/AnalysisStage.json",
  "title" : "AnalysisStage",
  "type" : ["object", "null"],
  "properties" : {
    "Elements" : {
      "type" : ["array", "null"],
      "description" : "List of objects to include in the Analysis Stage. This can be the following types: doubles, ints, strings and BHoMObjects.",
      "items" : { }
    },
    "Number" : {
      "type" : "integer",
      "description" : "GSA Id. This is an int. Must be greater than 0."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Adapters.GSA.Analysis.AnalysisStage"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["Elements", "Number"]
}
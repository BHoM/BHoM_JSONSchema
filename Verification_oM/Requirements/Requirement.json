    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : ["string", "null"],
      "description" : "Optional Type disciminator for BHoM type.",
      "const" : "BH.oM.Verification.Requirements.Requirement"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional Version of BHoM used when generating the object."

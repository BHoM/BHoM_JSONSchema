{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Analytical_oM/Fragments/RoutingFragment.json",
  "title" : "RoutingFragment",
  "type" : ["object", "null"],
  "description" : "RoutingFragment: Fragment used in the computation of shortest paths.",
  "properties" : {
    "MinCostToSource" : {
      "type" : ["number", "null"]
    },
    "Cost" : {
      "type" : ["number", "null"]
    },
    "Visited" : {
      "type" : "boolean"
    },
    "NearestToSource" : {
      "type" : "string",
      "format" : "uuid"
    },
    "StraightLineDistanceToTarget" : {
      "type" : ["number", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Analytical.Fragments.RoutingFragment"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["MinCostToSource", "Cost", "Visited", "NearestToSource", "StraightLineDistanceToTarget"]
}
{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/PowerPoint_oM/ImageUpdate.json",
  "title" : "ImageUpdate",
  "type" : ["object", "null"],
  "description" : "ImageUpdate: Allows to replace the image content of an image element.",
  "properties" : {
    "SlideNumber" : {
      "type" : "integer",
      "description" : "Number of the slide where the update needs to happen."
    },
    "ElementName" : {
      "type" : ["string", "null"],
      "description" : "Name of the image element that needs to be updated."
    },
    "ImageFilePath" : {
      "type" : ["string", "null"],
      "description" : "File path of the new image."
    },
    "BHoM_Guid" : {
      "type" : "string",
      "format" : "uuid"
    },
    "Name" : {
      "type" : ["string", "null"]
    },
    "Fragments" : {
      "$ref" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/develop/BHoM/FragmentSet.json"
    },
    "Tags" : {
      "type" : ["array", "null"],
      "items" : {
        "type" : ["string", "null"]
      },
      "uniqueItems" : true
    },
    "CustomData" : {
      "type" : ["object", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.PowerPoint.ImageUpdate"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["SlideNumber", "ElementName", "ImageFilePath"]
}
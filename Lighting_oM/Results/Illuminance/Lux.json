{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$id" : "https://raw.githubusercontent.com/BHoM/BHoM_JSONSchema/v8.3/Lighting_oM/Results/Illuminance/Lux.json",
  "title" : "Lux",
  "type" : ["object", "null"],
  "description" : "Lux: Lux contains results for Lux analysis. Inherits from MeshElementResult which provides properties related to which node this Lux is recorded for",
  "properties" : {
    "LuxLevel" : {
      "type" : ["object", "null"],
      "properties" : {
        "_v" : {
          "type" : ["array", "null"],
          "description" : "The amount of lux recorded for the given analysis node Property has a quantity of type Illuminance measured in [lux].",
          "items" : {
            "type" : "number"
          }
        }
      }
    },
    "ObjectId" : {
      "type" : ["object", "integer", "string", "number", "null"]
    },
    "NodeId" : {
      "type" : ["object", "integer", "string", "number", "null"]
    },
    "MeshFaceId" : {
      "type" : ["object", "integer", "string", "number", "null"]
    },
    "ResultCase" : {
      "type" : ["object", "integer", "string", "number", "null"]
    },
    "_t" : {
      "type" : "string",
      "description" : "Optional type disciminator.",
      "const" : "BH.oM.Lighting.Results.Illuminance.Lux"
    },
    "_bhomVersion" : {
      "type" : ["string", "null"],
      "description" : "Optional version of BHoM used as part of automatic versioning and schema upgrades."
    }
  },
  "required" : ["LuxLevel", "ObjectId", "NodeId", "MeshFaceId", "ResultCase"]
}